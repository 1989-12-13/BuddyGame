# 火山引擎语音合成 API (必填, 在 .env.local 中填入真实 key)
VOLCANO_TTS_KEY=

# 可选: 覆盖默认 endpoint
# VOLCANO_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional

# 可选: 覆盖默认资源 ID
# VOLCANO_TTS_RESOURCE=seed-tts-2.0

# 可选: 默认 speaker 音色, 默认 zh_female_vv_uranus_bigtts
# 可换成 zh_male_xxx 等其他音色, 名字以控制台实际为准
# VOLCANO_TTS_DEFAULT_SPEAKER=zh_female_vv_uranus_bigtts

# 音色池按 (性别 × 年龄档) 分配，集中在 src/audio/ttsSpeakers.ts 的 SPEAKER_POOL
# 如需更换，直接编辑该文件；以下是当前默认音色（与 .env 的 VOLCANO_TTS_DEFAULT_SPEAKER 兼容）：
#   男成人      zh_male_vv_uranus_bigtts
#   女成人      zh_female_vv_uranus_bigtts
#   男老人      zh_male_vv_uranus_bigtts   (待火山控制台提供更沙哑的音色后替换)
#   女老人      zh_female_vv_uranus_bigtts
#   小孩        zh_female_vv_uranus_bigtts (默认 fallback，可换成 zh_child_xxx 等真实童声)

# 可选: TTS 后端端口, 默认 8787
# PORT=8787